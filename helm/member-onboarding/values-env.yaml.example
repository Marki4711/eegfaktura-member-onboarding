# Umgebungsspezifische Konfiguration für member-onboarding.
#
# Kopiere diese Datei nach values-env.yaml und passe die Werte an.
# values-env.yaml ist gitignored und wird NICHT committed.
#
# Verwendung:
#   helm install eegfaktura-member-onboarding ./helm/member-onboarding \
#     -f helm/member-onboarding/values-env.yaml \
#     -f helm/member-onboarding/values-secret.yaml

# ── Namespace ──────────────────────────────────────────────────────────────────
namespace: eegfaktura-member-onboarding

# ── Ingress ────────────────────────────────────────────────────────────────────
ingress:
  host: member-onboarding.example.at
  className: nginx
  # Timeout in Sekunden für lange Requests (z.B. Datei-Uploads)
  # proxyReadTimeout: "60"
  # proxySendTimeout: "60"

# ── Images ─────────────────────────────────────────────────────────────────────
images:
  backend:
    repository: marki4711/eegfaktura-member-onboarding-backend
    # tag: sha-xxxxxxx  # Leer lassen → verwendet den Tag aus values.yaml (empfohlen)
    # "latest" vermeiden: verhindert reproduzierbare Deployments und wird von Kubernetes
    # bei pullPolicy: IfNotPresent nicht neu gezogen.
    pullPolicy: IfNotPresent
  frontend:
    repository: marki4711/eegfaktura-member-onboarding-frontend
    # tag: sha-xxxxxxx  # Leer lassen → verwendet den Tag aus values.yaml (empfohlen)
    pullPolicy: IfNotPresent

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
postgres:
  user: postgres
  database: member_onboarding
  # StorageClass des Kubernetes-Clusters (kubectl get storageclass)
  storageClassName: csi-rbd-sc
  storageSize: 5Gi

# ── Frontend ───────────────────────────────────────────────────────────────────
frontend:
  # Anzahl der Frontend-Pods (horizontal scaling)
  replicas: 1

  # Log-Level für den Next.js Node.js Server-Prozess: debug | info | warn | error
  logLevel: "info"

  # Interne Kubernetes-URL des Backend-Service (für SSR-Requests vom Frontend-Pod)
  # Format: http://<release-name>-backend:8080
  # Beispiel: http://eegfaktura-member-onboarding-backend:8080
  backendUrl: "http://RELEASE-NAME-backend:8080"

  # NextAuth — Öffentliche URL der App (muss exakt mit dem Browser-Aufruf übereinstimmen)
  nextauthUrl: "https://member-onboarding.example.at"

  # Keycloak Issuer URL (Realm-URL ohne trailing slash)
  keycloakIssuer: "https://keycloak.example.at/realms/EEGFaktura"

  # Keycloak Client ID (entspricht dem konfigurierten Client in Keycloak)
  keycloakClientId: "eegfaktura-member-onboarding"

# ── Backend ────────────────────────────────────────────────────────────────────
backend:
  # Anzahl der Backend-Pods (horizontal scaling)
  replicas: 1

  # Log-Level: DEBUG | INFO | WARN | ERROR
  # DEBUG: alle Details inkl. DB-Queries (nur für Fehleranalyse)
  # INFO:  normaler Betrieb (empfohlen für Produktion)
  # WARN:  nur Warnungen und Fehler
  # ERROR: nur Fehler
  logLevel: "INFO"

  # Erlaubte Origins für CORS (kommagetrennt für mehrere)
  corsAllowedOrigins: "https://member-onboarding.example.at"

  # Keycloak JWT-Validierung (JWKS-Endpoint und Issuer)
  # Leer lassen = Dev-Modus (kein Auth, alle Admin-Requests durchgelassen)
  keycloakJwksUrl: "https://keycloak.example.at/realms/EEGFaktura/protocol/openid-connect/certs"
  keycloakIssuer: "https://keycloak.example.at/realms/EEGFaktura"

  # SMTP-Konfiguration für E-Mail-Benachrichtigungen
  # Auskommentiert lassen = Mail deaktiviert (NoOpMailService)
  # smtp:
  #   host: smtp.example.com
  #   port: "587"
  #   # Leer lassen bei open relay (kein Auth erforderlich)
  #   user: noreply@example.com
  #   # Pflichtfeld wenn host gesetzt — Absenderadresse
  #   from: noreply@example.com

  # eegFaktura Core Service (PROJ-4 Import)
  # Leer lassen = Import-Endpoint deaktiviert (Aufruf liefert 503).
  # Wenn gesetzt: Backend ruft <coreBaseUrl>/participant auf, mit dem Bearer-JWT
  # des angemeldeten Admins und dem tenant-Header (RC-Nummer).
  # Achtung: Pfad-Präfix (typischerweise /api) gehört in die URL — die deployten
  # eegFaktura-Cores stehen i.d.R. hinter einem Reverse-Proxy unter /api/*.
  coreBaseUrl: "https://eegfaktura.example.at/api"
  coreTimeoutSeconds: 30

# ── Seed data ──────────────────────────────────────────────────────────────────
# Wird einmalig als post-install Hook ausgeführt.
# Legt einen initialen Registrierungseinstiegspunkt an.
# Mehrfaches Ausführen ist sicher (ON CONFLICT DO NOTHING).
seed:
  rcNumber: RC123456
  eegId: "00000000-0000-0000-0000-000000000001"

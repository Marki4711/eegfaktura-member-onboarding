# Kopiere diese Datei nach values-secret.yaml und trage die echten Werte ein.
# values-secret.yaml ist in .helmignore gelistet und wird NICHT committed.
#
# Verwendung:
#   helm install member-onboarding ./helm/member-onboarding \
#     -f helm/member-onboarding/values-secret.yaml

secrets:
  postgresPassword: "FILL_IN"   # Passwort für In-Cluster-PostgreSQL
  dbPassword: "FILL_IN"         # Muss identisch mit postgresPassword sein
  smtpPassword: ""              # Leer lassen wenn kein SMTP-Auth erforderlich

# SMTP aktivieren (optional):
# backend:
#   smtp:
#     host: smtp.example.com
#     port: "587"
#     user: noreply@example.com
#     from: noreply@example.com

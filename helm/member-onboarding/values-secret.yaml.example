# Geheime Konfiguration für member-onboarding.
#
# Kopiere diese Datei nach values-secret.yaml und trage die echten Werte ein.
# values-secret.yaml ist gitignored und wird NICHT committed.
#
# Verwendung:
#   helm install eegfaktura-member-onboarding ./helm/member-onboarding \
#     -f helm/member-onboarding/values-env.yaml \
#     -f helm/member-onboarding/values-secret.yaml

# ── Datenbankpasswörter ────────────────────────────────────────────────────────
secrets:
  # Passwort für den In-Cluster-PostgreSQL-Pod (POSTGRES_PASSWORD)
  postgresPassword: "FILL_IN"

  # Muss identisch mit postgresPassword sein (wird als DB_PASSWORD ans Backend übergeben)
  dbPassword: "FILL_IN"

  # SMTP-Authentifizierungspasswort
  # Leer lassen wenn kein SMTP-Auth erforderlich (open relay oder Mail deaktiviert)
  smtpPassword: ""

  # NextAuth Session Encryption Key (mind. 32 Zeichen, zufällig generiert)
  # Generieren: openssl rand -base64 32
  nextauthSecret: "FILL_IN"

  # Keycloak Client Secret (aus Keycloak Admin Console: Clients → eegfaktura-member-onboarding → Credentials)
  keycloakClientSecret: "FILL_IN"

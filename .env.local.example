# Backend API URL
# Points to the Go backend. For local development, backend runs on :8080.
NEXT_PUBLIC_API_URL=http://localhost:8080

# SMTP configuration (optional — leave SMTP_HOST empty to disable email sending)
# When SMTP_HOST is set, SMTP_FROM is required.
# SMTP_USER / SMTP_PASSWORD can be left empty for open-relay / internal SMTP servers.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# NextAuth — required for admin authentication
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Keycloak OIDC settings
# Realm: EEGFaktura, Client: eegfaktura-member-onboarding
KEYCLOAK_CLIENT_ID=eegfaktura-member-onboarding
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=https://auth.example.com/realms/EEGFaktura

# Go backend — Keycloak JWT validation (same issuer as above)
# KEYCLOAK_JWKS_URL=https://auth.example.com/realms/EEGFaktura/protocol/openid-connect/certs
# KEYCLOAK_ISSUER=https://auth.example.com/realms/EEGFaktura
# Leave KEYCLOAK_JWKS_URL empty to disable auth in local dev (all admin requests pass through)

# Cloudflare Turnstile — CAPTCHA für das öffentliche Beitrittsformular (optional)
# Leer lassen zum Deaktivieren (Dev-Modus ohne CAPTCHA).
# Site Key: im Cloudflare-Dashboard unter Turnstile > Add Site erzeugen.
# Secret Key: wird nur vom Go-Backend benötigt (nicht im Frontend).
# Test-Keys (immer erfolgreich): Site Key=1x00000000000000000000AA, Secret Key=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Admin-Basis-URL — wird für den direkten Link in der EEG-Einreichungs-E-Mail verwendet.
# Für alle EEGs gleich (globale Deployment-Variable). Leer lassen zum Deaktivieren.
ADMIN_BASE_URL=

# Public-Basis-URL — extern erreichbare URL der öffentlichen Frontend-Domain
# (z. B. https://onboarding.eeg-x.at). Wird für die Bestätigungs-Link-URL in
# der Member-Mail benötigt (PROJ-31). Leer lassen deaktiviert die
# E-Mail-Bestätigung — der entsprechende EEG-Setting greift dann nicht.
PUBLIC_BASE_URL=

# Zentrale Datenschutzerklärung — wird immer als Pflichtdokument im Registrierungsformular angezeigt.
# Leer lassen für Standardtitel "Datenschutzerklärung" (ohne Link).
CENTRAL_POLICY_TITLE=Datenschutzerklärung
CENTRAL_POLICY_URL=

# eegFaktura Core service for participant import (PROJ-4).
# CORE_BASE_URL: base URL of the core service (e.g. https://eegfaktura-core.example.at).
# Leave empty to disable the import endpoint — calling it returns 503.
# CORE_TIMEOUT_SECONDS: HTTP timeout for participant creation calls (default: 30).
CORE_BASE_URL=
CORE_TIMEOUT_SECONDS=30

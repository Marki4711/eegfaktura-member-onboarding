#!/usr/bin/env bash
#
# Pre-Commit Hook für PROJ-54 — defensive Schicht.
#
# Verhindert, dass `private/`-Pfade oder Dateien mit Frontmatter
# `visibility: private` versehentlich auf einem Branch landen, der
# später ohne Filter ins Public-Repo gepusht wird.
#
# Aktivierung im privaten Repo:
#   git config core.hooksPath .githooks
#
# Skript-Logik:
#   - Auf `main` und sonstigen Branches: nur warnen, nicht blockieren —
#     der Mirror-Workflow filtert ohnehin.
#   - Auf Branches `mirror/*` oder `public-*`: HART abbrechen, wenn
#     private/-Pfade oder visibility:private-Marker im Commit sind.
#     (Convention: solche Branches wären ein direkter Push ins Public.)

set -euo pipefail

# Aktuellen Branch ermitteln
BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || echo "")"

# Staged Dateien holen
STAGED="$(git diff --cached --name-only --diff-filter=ACM)"
[[ -z "$STAGED" ]] && exit 0

is_mirror_target_branch() {
    case "$BRANCH" in
        mirror/*|public-*|public) return 0 ;;
        *) return 1 ;;
    esac
}

# private/ Pfade prüfen
private_paths=()
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    if [[ "$file" == private/* ]]; then
        private_paths+=("$file")
    fi
done <<< "$STAGED"

# visibility: private Frontmatter prüfen
private_frontmatter=()
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ "$file" == *.md ]] || continue
    [[ -f "$file" ]] || continue

    first_line="$(head -n 1 "$file" 2>/dev/null || echo "")"
    [[ "$first_line" == "---" ]] || continue

    fm="$(awk '
        NR == 1 && /^---$/ { in_fm = 1; next }
        in_fm && /^---$/   { in_fm = 0; exit }
        in_fm              { print }
    ' "$file")"

    if echo "$fm" | grep -qE '^[[:space:]]*visibility:[[:space:]]*private[[:space:]]*$'; then
        private_frontmatter+=("$file")
    fi
done <<< "$STAGED"

# Auswertung
has_private_content=0
if [[ ${#private_paths[@]} -gt 0 || ${#private_frontmatter[@]} -gt 0 ]]; then
    has_private_content=1
fi

if [[ $has_private_content -eq 1 ]]; then
    if is_mirror_target_branch; then
        echo "ERROR: Branch '$BRANCH' looks like a mirror/public target." >&2
        echo "Refusing to commit private-marked content on this branch." >&2
        echo "" >&2
        if [[ ${#private_paths[@]} -gt 0 ]]; then
            echo "  private/ paths in staged changes:" >&2
            printf '    %s\n' "${private_paths[@]}" >&2
        fi
        if [[ ${#private_frontmatter[@]} -gt 0 ]]; then
            echo "  visibility:private frontmatter in staged files:" >&2
            printf '    %s\n' "${private_frontmatter[@]}" >&2
        fi
        echo "" >&2
        echo "Hint: commit these on 'main' instead — the mirror workflow filters them out." >&2
        exit 1
    else
        # Auf regulären Branches nur informativ
        if [[ ${#private_paths[@]} -gt 0 ]]; then
            echo "ℹ private/ paths in this commit (will be filtered from public mirror):"
            printf '    %s\n' "${private_paths[@]}"
        fi
        if [[ ${#private_frontmatter[@]} -gt 0 ]]; then
            echo "ℹ files with visibility:private (will be filtered from public mirror):"
            printf '    %s\n' "${private_frontmatter[@]}"
        fi
    fi
fi

exit 0

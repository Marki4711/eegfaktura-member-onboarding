#!/usr/bin/env bash
#
# Pre-Push Hook für PROJ-54 — letzte Verteidigungslinie.
#
# Blockt einen `git push`, wenn:
#   - das Remote auf das Public-Repo zeigt (Direkt-Push ins Public ist
#     nach Cutover nur via Mirror-Workflow erlaubt)
#   - ODER ein Push auf einen "mirror-target"-Branch (mirror/*, public-*)
#     ungefilterte private/-Pfade enthält
#
# Aktivierung im privaten Repo:
#   git config core.hooksPath .githooks
#
# Stdin-Format (Git ruft den Hook mit Lines auf):
#   <local_ref> <local_sha> <remote_ref> <remote_sha>

set -euo pipefail

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"

# Direkten Push ins Public-Repo blockieren
if [[ "$REMOTE_URL" == *"Marki4711/eegfaktura-member-onboarding.git"* ]] && \
   [[ "$REMOTE_URL" != *"-private"* ]]; then
    echo "ERROR: Direct push to public mirror repo is forbidden." >&2
    echo "" >&2
    echo "  Remote: $REMOTE_NAME → $REMOTE_URL" >&2
    echo "" >&2
    echo "After cutover, the public repo is updated only via the Mirror" >&2
    echo "Workflow in the private repo. Direct pushes bypass the filter and" >&2
    echo "may leak private/ paths or visibility:private files." >&2
    echo "" >&2
    echo "If this is intentional (one-time cutover or maintenance), bypass" >&2
    echo "this hook with:" >&2
    echo "  git -c core.hooksPath= push $REMOTE_NAME ..." >&2
    exit 1
fi

# Branch-spezifische Prüfung
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    # Branch-Name aus local_ref ableiten (refs/heads/foo → foo)
    branch="${local_ref#refs/heads/}"

    case "$branch" in
        mirror/*|public-*|public)
            # Auf solchen Branches: keine private/-Pfade erlaubt
            # Vergleich gegen remote_sha — wenn 000…0, ist es ein neuer Branch
            if [[ "$remote_sha" =~ ^0+$ ]]; then
                range="$local_sha"
            else
                range="${remote_sha}..${local_sha}"
            fi

            # Alle in diesem Range geänderten Dateien holen
            files="$(git diff --name-only "$range" 2>/dev/null || echo "")"

            leaked=()
            while IFS= read -r f; do
                [[ -z "$f" ]] && continue
                [[ "$f" == private/* ]] && leaked+=("$f")
            done <<< "$files"

            if [[ ${#leaked[@]} -gt 0 ]]; then
                echo "ERROR: Push to '$branch' would expose private/ paths:" >&2
                printf '    %s\n' "${leaked[@]}" >&2
                echo "" >&2
                echo "Mirror-target branches must NEVER carry private/ content." >&2
                exit 1
            fi
            ;;
    esac
done

exit 0
